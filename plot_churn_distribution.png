    "            annot_kws={'size': 7}, cbar_kws={'shrink': 0.8})\n",
    "ax.set_title('Heatmap Korelasi Fitur Numerik', fontsize=14, fontweight='bold', pad=12)\n",
    "plt.xticks(rotation=45, ha='right', fontsize=8)\n",
